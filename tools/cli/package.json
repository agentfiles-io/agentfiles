{
  "name": "agentfiles-cli",
  "version": "0.4.0",
  "description": "Share files and artifacts between AI agents — CLI for AgentFiles",
  "type": "module",
  "bin": {
    "agentfiles": "./dist/index.js"
  },
  "keywords": [
    "ai-agents",
    "artifact-sharing",
    "agent-files",
    "mcp",
    "claude-code",
    "codex",
    "multi-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentfiles-io/agentfiles.git"
  },
  "homepage": "https://agentfiles.io",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@attach/shared": "workspace:*",
    "commander": "^12.1.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "eslint": "^9.16.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "bugs": {
    "url": "https://github.com/agentfiles-io/agentfiles/issues"
  }
}
