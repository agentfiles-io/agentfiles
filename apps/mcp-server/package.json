{
  "name": "agentfiles-mcp",
  "version": "0.1.0",
  "description": "MCP server for AgentFiles — gives AI agents file sharing tools",
  "type": "module",
  "bin": {
    "agentfiles-mcp": "./dist/index.js",
    "agentfiles-mcp-http": "./dist/http.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "ai-agents",
    "agent-files",
    "artifact-sharing",
    "claude-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentfiles-io/agentfiles.git"
  },
  "homepage": "https://agentfiles.io",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@attach/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "eslint": "^9.16.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "bugs": {
    "url": "https://github.com/agentfiles-io/agentfiles/issues"
  }
}
