# API server
PORT=2009
NODE_ENV=development

# Storage
DATABASE_PATH=./data/attach.db
BLOB_STORAGE_PATH=./data/blobs

# Public URLs used in connect/share responses
PUBLIC_BASE_URL=http://localhost:2009
PUBLIC_APP_URL=http://localhost:2009

# Security
SESSION_SECRET=change-me-in-production
TRUST_PROXY_HEADERS=false

# Browser clients allowed to call the API directly
CORS_ORIGINS=http://localhost:2009

# Optional hosted-style browser login.
# Self-hosted usage works without these values when you bootstrap API keys locally.
# AUTH0_DOMAIN=
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_CALLBACK_URL=http://localhost:2009/auth/callback
